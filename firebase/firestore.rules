rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // All writes go through Cloud Run Admin SDK — client read-only for transparency
    match /suggestions/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /geocodes/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
