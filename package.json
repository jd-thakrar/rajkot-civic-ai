{
  "name": "mp-pulse-platform",
  "version": "2.0.0",
  "type": "module",
  "description": "Real AI-Powered Multilingual MP Development Prioritization Platform",
  "scripts": {
    "dev": "vite",
    "server": "node src/server/index.js",
    "start": "concurrently \"node src/server/index.js\" \"vite\"",
    "build": "vite build",
    "migrate": "node scripts/migrate-to-firestore.js",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "fetch:wards": "node fetch_rmc_ward_boundaries.cjs",
    "geocode:areas": "node geocode_areas.cjs",
    "build:wards": "node build_ward_boundaries.cjs",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@turf/turf": "^7.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.10.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "puppeteer": "^25.3.0",
    "vite": "^5.0.0"
  }
}
