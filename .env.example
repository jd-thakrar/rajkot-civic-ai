# RMC Seva Portal — Environment Variables

# ─── Google AI & Maps ───
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Firebase (server — Cloud Run uses ADC if only PROJECT_ID is set) ───
FIREBASE_PROJECT_ID=your-firebase-project-id
# Local dev: paste service account JSON as a single line (optional if using gcloud auth application-default login)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ─── Firebase (client — Vite exposes VITE_ prefixed vars) ───
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Server ───
PORT=3000
NODE_ENV=development
DATA_DIR=./data
